# ============================================================================
# VoxReel — environment variables (EXAMPLE)
#
# Copy this file to `.env.local` and fill in real values when you start wiring
# the backend. DO NOT commit `.env.local` or any real secrets.
#
# The app is currently frontend-only and does NOT read these yet.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# Project URL and anon key are safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key is SECRET — server-side only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI / media providers (server-side only, not used yet) ------------------
OPENAI_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
